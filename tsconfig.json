{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "moduleResolution": "node16",
    "module": "node16",
    "types": ["node"],
    "typeRoots": ["./node_modules/@types"],
    "declaration": true,
    "resolveJsonModule": true,
    "outDir": "dist"
  },
  "include": [
    "bin.tsx",
    "src/**/*"
  ]
}
