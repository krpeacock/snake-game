{
  "name": "@pavus/snake-game",
  "version": "1.1.1",
  "description": "Playable Snake in the terminal with MIDI music",
  "type": "module",
  "bin": {
    "snake-game": "dist/bin.js"
  },
  "main": "dist/src/index.js",
  "typings": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "package.json"
  ],
  "scripts": {
    "clean": "rm -rf ./dist",
    "prebuild": "pnpm clean",
    "build": "pnpm tsc",
    "postbuild": "chmod +x ./dist/bin.js && cp scripts/snake-synth.mjs dist/",
    "link": "pnpm link --global",
    "build:link": "pnpm build && pnpm link --global",
    "try": "tsx bin.tsx",
    "start": "node dist/bin.js"
  },
  "dependencies": {
    "midi-file": "^1.2.4"
  },
  "peerDependencies": {
    "ink": ">=4.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^18.19.76",
    "@types/react": "^19.2.14",
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "tsx": "^4.20.3",
    "typescript": "^5.0.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48"
}
